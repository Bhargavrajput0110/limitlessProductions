{
  "name": "limitless-productions-optimized",
  "version": "2.0.0",
  "description": "Limitless Productions - Performance Optimized",
  "scripts": {
    "build": "node build-with-hash.js",
    "build:old": "node build-bundle.js",
    "build:analyze": "node build-with-hash.js --analyze",
    "optimize:images": "node optimize-images.js",
    "optimize:videos": "./optimize-videos.sh",
    "build:css": "tailwindcss -i ./src/input.css -o ./dist/output.css --minify",
    "watch:css": "tailwindcss -i ./src/input.css -o ./dist/output.css --watch",
    "critical:css": "node extract-critical-css.js",
    "dev": "npm run watch:css",
    "prod": "NODE_ENV=production node build-with-hash.js && npm run optimize:images",
    "analyze": "npm run build:analyze && webpack-bundle-analyzer dist/meta.json",
    "lighthouse": "lighthouse https://limitlessproductions.in --view",
    "test:perf": "node test-performance.js",
    "cache:clear": "node -e \"navigator.serviceWorker.getRegistrations().then(r => r.forEach(reg => reg.unregister()))\"",
    "cache:stats": "node cache-stats.js"
  },
  "dependencies": {
    "@react-spring/three": "^10.0.3",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@studio-freight/lenis": "^1.0.39",
    "gsap": "^3.12.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadergradient": "^1.3.5",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@types/three": "^0.160.0",
    "autoprefixer": "^10.4.17",
    "critical": "^6.0.0",
    "esbuild": "^0.27.4",
    "lighthouse": "^11.5.0",
    "postcss": "^8.4.35",
    "sharp": "^0.33.2",
    "tailwindcss": "^3.4.1",
    "webpack-bundle-analyzer": "^4.10.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
